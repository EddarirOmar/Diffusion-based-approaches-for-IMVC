# Allowlist policy: only content under DCG/ and DMVG/ is publishable.

# Ignore everything by default.
*

# Keep this file tracked.
!.gitignore
!.gitattributes

# Allow DCG and DMVG trees.
!DCG/
!DCG/**
!DCG (NEW)/
!DCG (NEW)/**
!DMVG/
!DMVG/**
!IMVCDC/
!IMVCDC/**

# Ignore common generated files even inside allowed trees.
__pycache__/
*.py[cod]
*$py.class
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
*.md

# Keep markdown files inside explicitly published trees.
# !DCG/**/*.md
# !DCG (NEW)/**/*.md
# !DMVG/**/*.md
# !IMVCDC/**/*.md